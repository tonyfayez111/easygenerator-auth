# Copy this file to .env and fill in the values before running docker compose up

# ── Backend ───────────────────────────────────────────────────────────────────
# REQUIRED: change before going to production (min 32 random characters)
JWT_SECRET=change_me_in_production_min_32_chars!!

JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# URL the browser uses to reach the backend API
CORS_ORIGIN=http://localhost:80

# ── Frontend ──────────────────────────────────────────────────────────────────
# Baked into the Vite bundle at Docker build time — must be the public URL
# of the backend as seen from the user's browser (not inside Docker network)
VITE_API_URL=http://localhost:3000

# ── Port overrides (optional) ─────────────────────────────────────────────────
# BACKEND_PORT=3000
# FRONTEND_PORT=80
