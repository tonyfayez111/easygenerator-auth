# Copy this file to .env and fill in real values — docker compose reads it automatically.
# Any variable left commented out falls back to the default in docker-compose.yml.

NODE_ENV=development

# Change this before sharing or deploying (min 32 random characters)
JWT_SECRET=dev_secret_change_me_min_32_characters!!

JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

MONGODB_URI=mongodb://mongo:27017/easygenerator
CORS_ORIGIN=http://localhost

# URL the browser uses to reach the backend (baked into the frontend bundle at build time)
VITE_API_URL=http://localhost:3000
